# =============================================================================
# .env.example — Copia in .env e personalizza
#   cp .env.example .env
# =============================================================================

# Immagine Docker
DOCKER_IMAGE=bunnydrummer/suitecrm:latest

# Directory dati (bind mounts) — percorso assoluto
DATA_DIR=/opt/suitecrm/data

# Porta HTTP esposta sull'host
HTTP_PORT=8080

# Timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=Europe/London

# Database
DB_ROOT_PASSWORD=changeme_root
DB_NAME=suitecrm
DB_USER=suitecrm
DB_PASSWORD=changeme_suitecrm
